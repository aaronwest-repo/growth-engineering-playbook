# Static commerce stack — example environment (TEMPLATE).
# Copy to .env and fill in your own values. Never commit a real .env.
# These are placeholders only; no real values ship in this repo.

# Object storage bucket that holds the built site.
STATIC_BUCKET_NAME=STATIC_BUCKET_NAME

# CDN distribution in front of the bucket.
CDN_DISTRIBUTION_ID=CDN_DISTRIBUTION_ID

# Local build output directory.
BUILD_DIR=./dist

# Public domain served by the CDN.
SITE_DOMAIN=SITE_DOMAIN

# Safety switch for the template deploy script. 1 = dry-run (default).
DRY_RUN=1
